{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist-tests",
    "rootDir": "."
  },
  "include": ["src/features/**/*.ts", "src/types/**/*.ts", "tests/**/*.ts"]
}
